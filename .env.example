# ralph-claw environment variables
# Copy to .env and fill in your values

# Provider: claude | gemini | codex
PROVIDER=claude

# API Keys — only the one you use is needed
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# Loop config
SLEEP_BETWEEN_LOOPS=10   # seconds between iterations
MAX_LOOPS=0              # 0 = infinite

# Agent Teams (Claude Code only)
# AGENT_MODE: single = one agent per loop (default), team = parallel teammates
AGENT_MODE=single
TEAM_SIZE=3              # number of teammates in team mode
